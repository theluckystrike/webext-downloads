{
  "name": "@anthropic/webext-downloads",
  "version": "1.0.0",
  "description": "Typed download helpers for Chrome extensions. Part of @zovo/webext.",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts",
    "test": "vitest run",
    "prepare": "npm run build"
  },
  "keywords": [
    "chrome-extension",
    "downloads",
    "download-manager",
    "typescript",
    "webextension",
    "browser-extension",
    "manifest-v3",
    "chrome-downloads",
    "file-download"
  ],
  "author": "",
  "license": "MIT",
  "packageManager": "pnpm@10.30.3",
  "devDependencies": {
    "@types/chrome": "^0.1.37",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  }
}
